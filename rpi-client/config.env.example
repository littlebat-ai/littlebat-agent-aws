# Copy this file to config.env and fill in the values.
# Run `terraform output` after deploying to get these values.

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=         # terraform output device_access_key_id
AWS_SECRET_ACCESS_KEY=     # terraform output -raw device_secret_access_key

# ── Bedrock AgentCore ─────────────────────────────────────────────────────────
# AWS Console → Amazon Bedrock → AgentCore → Agent Runtimes → copy ARN
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/XXXXXXXXXX

# ── Amazon Polly voice ────────────────────────────────────────────────────────
# Neural voices: Matthew Joanna Joey Kendra Kimberly Salli Kevin Ivy Justin Ruth Stephen
POLLY_VOICE=Matthew

# ── Audio recording ───────────────────────────────────────────────────────────
# Default 16kHz mono works with WM8960. If arecord errors, try 48000 / 2.
RECORD_RATE=16000
RECORD_CHANNELS=1
